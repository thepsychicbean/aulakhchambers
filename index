            </div>
        </div>
    </section>

    <footer id="contact">
        <div class="footer-grid">
            <div class="footer-col">
                <h4>CHAMBERS</h4>
                <p>Room No. 30, New Bar Complex</p>
                <p>Punjab & Haryana High Court</p>
                <p>Chandigarh</p>
            </div>
            <div class="footer-col">
                <h4>OFFICE</h4>
                <p>H.No. 40, Phase-4</p>
                <p>Sector 59, Mohali</p>
                <p>Punjab</p>
            </div>
            <div class="footer-col">
                <h4>CONTACT</h4>
                <p><strong>Direct:</strong> +91 98888-99650</p>
                <p><strong>Clerk (Rafiq):</strong> +91 95011-34650</p>
