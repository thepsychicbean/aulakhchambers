            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <section class="hero">
        <div class="hero-content">
            <i class="bi bi-balance-scale" style="font-size: 3rem; color: var(--accent-gold); margin-bottom: 20px; display: block;"></i>
            <h1>Excellence In Advocacy.</h1>
