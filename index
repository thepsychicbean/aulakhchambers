<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aulakh Chambers | Advocates & Legal Consultants</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-dark: #121212;
            --accent-gold: #c5a059;
            --deep-burgundy: #4a0e0e; /* Inspired by the office leather chairs */
            --off-white: #fcfaf7;
            --text-gray: #555;
            --transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--off-white);
            color: var(--primary-dark);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* --- Navigation --- */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 8%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            position: fixed;
            width: 100%;
            z-index: 1000;
            border-bottom: 1px solid rgba(197, 160, 89, 0.2);
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: var(--primary-dark);
            text-transform: uppercase;
        }

        .nav-links {
            display: flex;
            list-style: none;
        }

        .nav-links li { margin-left: 2.5rem; }

        .nav-links a {
            text-decoration: none;
            color: var(--primary-dark);
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: var(--transition);
        }

        .nav-links a:hover { color: var(--accent-gold); }

        /* --- Hero Section --- */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), 
                        url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&q=80&w=2000'); /* Professional placeholder */
            background-size: cover;
            background-attachment: fixed;
            color: white;
            padding: 0 5%;
        }

        .hero-content h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 400;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
        }

        .hero-content p {
            font-size: 1.1rem;
            max-width: 700px;
            margin: 0 auto 2rem;
            font-weight: 300;
            letter-spacing: 1px;
            opacity: 0.9;
        }

        .btn-cta {
            padding: 1.2rem 2.5rem;
            background: var(--accent-gold);
            color: white;
            text-decoration: none;
            text-transform: uppercase;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 2px;
            transition: var(--transition);
            border: 1px solid var(--accent-gold);
        }

        .btn-cta:hover {
            background: transparent;
            color: var(--accent-gold);
            backdrop-filter: blur(5px);
        }

        /* --- Practice Grid --- */
        .section-padding { padding: 8rem 10%; }

        .section-header { text-align: center; margin-bottom: 5rem; }

        .section-header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .gold-divider {
            width: 60px;
            height: 2px;
            background: var(--accent-gold);
            margin: 0 auto;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .card {
            background: #fff;
            padding: 3rem 2rem;
            border: 1px solid rgba(0,0,0,0.05);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .card:hover {
            transform: translateY(-10px);
            border-color: var(--accent-gold);
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        }

        .card i {
            font-size: 2rem;
            color: var(--accent-gold);
            margin-bottom: 1.5rem;
            display: block;
        }

        .card h3 {
            font-family: 'Playfair Display', serif;
            margin-bottom: 1rem;
            font-size: 1.5rem;
        }

        /* --- Contact/Footer --- */
        footer {
            background: var(--primary-dark);
            color: #fff;
            padding: 5rem 10% 2rem;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 4rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 4rem;
        }

        .footer-col h4 {
            color: var(--accent-gold);
            font-family: 'Playfair Display', serif;
            margin-bottom: 1.5rem;
            font-size: 1.2rem;
        }

        .footer-col p {
            font-size: 0.9rem;
            opacity: 0.7;
            margin-bottom: 0.5rem;
        }

        .disclaimer {
            text-align: center;
            font-size: 0.7rem;
            opacity: 0.4;
            padding-top: 2rem;
            max-width: 800px;
            margin: 0 auto;
        }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            .hero-content h1 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

    <nav>
        <div class="logo">Aulakh Chambers</div>
        <ul class="nav-links">
            <li><a href="#practices">Practice Areas</a></li>
